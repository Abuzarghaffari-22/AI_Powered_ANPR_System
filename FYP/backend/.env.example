# Copy this file to .env and fill in your values
SECRET_KEY=your-random-secret-key-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

DB_HOST=localhost
DB_USER=anpr_user
DB_PASSWORD=your-db-password
DB_NAME=anpr_db
DB_PORT=3306
DB_POOL_SIZE=25

CAMERA_INDEX=0
CAMERA_IP=192.168.1.100

PROCESS_EVERY_N_FRAMES=1
YOLO_INPUT_W=640
ALLOWED_ORIGINS=http://localhost:3000

ADMIN_USERNAME=admin
ADMIN_PASSWORD=YourStrongPassword123!

CONF_THRESHOLD=0.45
STABLE_FRAMES=2
SAME_PLATE_COOLDOWN=8.0

MIN_PLATE_W=40
MAX_PLATE_W=900
MIN_ASPECT=1.1
MAX_ASPECT=7.0
MAX_FRAME_FRAC=0.35
SKY_SKIP_FRAC=0.04

BLUR_THRESHOLD=18.0
LOW_LIGHT_THRESHOLD=45.0
ENABLE_LOW_LIGHT_BOOST=1

MIN_OCR_CONF=0.75
